# Vercel / Next.js production: isi dengan URL PaddleOCR service di Render.
PADDLEOCR_SERVICE_URL=https://your-render-service.onrender.com
PADDLEOCR_LANG=en

# Local development fallback jika tidak memakai Render.
PADDLEOCR_PYTHON_COMMAND=python
PADDLEOCR_CACHE_HOME=.paddle-cache
PADDLE_PDX_CACHE_HOME=.paddlex-cache
